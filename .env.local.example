# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Auth: add this exact redirect URL in Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
#   {NEXT_PUBLIC_APP_URL}/auth/callback
# (and your production origin, e.g. https://yourdomain.com/auth/callback)

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# For local dev: run `pnpm run webhooks:listen`, then paste the signing secret (whsec_...) here.
# Do not use the Dashboard endpoint URL for localhost; use the CLI instead.
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_PERCENT=10

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@mcmmerchant.net

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: canonical public URL for storefront share links (defaults to NEXT_PUBLIC_APP_URL)
# NEXT_PUBLIC_SITE_URL=https://mcmmerchant.net
NEXT_PUBLIC_APP_NAME=MCMerchant

