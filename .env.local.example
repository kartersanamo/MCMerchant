# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Must be the service_role key (Project Settings → API), not the anon key.
# Used for routes that bypass RLS (e.g. clearing purchase.version_id when deleting a version).
SUPABASE_SERVICE_ROLE_KEY=
# Auth: add these redirect URLs in Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
#   {NEXT_PUBLIC_APP_URL}/auth/callback
#   {NEXT_PUBLIC_APP_URL}/auth/update-password
# (and your production origin, e.g. https://yourdomain.com/auth/callback)
# Email change uses /auth/callback; password reset links must be allowed to return to /auth/update-password.
# Configure custom SMTP under Authentication → Emails if Supabase returns errors when sending auth emails.
#
# If creating plugins fails with "row-level security policy for table plugins", run docs/supabase-rls-plugins.sql
# in the Supabase SQL editor (dashboard plugin APIs use the user's session + RLS).

# Stripe
# Test: pk_test_... + sk_test_...  |  Production: pk_live_... + sk_live_...
# Connect onboarding is the same URL flow; only the keys decide test vs real accounts/payouts.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Test webhooks: run `pnpm run webhooks:listen`, paste whsec_... here.
# Production: create a LIVE webhook endpoint in Stripe Dashboard → Webhooks (not test mode), then paste its signing secret.
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_PERCENT=10

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@mcmerchant.net

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: canonical public URL for storefront share links (defaults to NEXT_PUBLIC_APP_URL)
# NEXT_PUBLIC_SITE_URL=https://mcmerchant.net
#
# Production: set NEXT_PUBLIC_APP_URL to exactly ONE public origin (https), including your chosen
# www or non-www hostname, e.g. https://mcmerchant.net OR https://www.mcmerchant.net.
# In production builds, middleware 301-redirects HTTP→HTTPS and the other www/apex variant to this host
# (only for that domain — seller custom domains and *.vercel.app are not redirected).
# Set DISABLE_CANONICAL_REDIRECT=1 to turn that off (e.g. unusual hosting).
NEXT_PUBLIC_APP_NAME=MCMerchant
# Optional: HTTPS URL shown in footer as “Open source” (e.g. GitHub org/repo). Not set = link hidden.
# NEXT_PUBLIC_GITHUB_URL=https://github.com/your-org/mcmerchant

MERCHANT_WEBHOOK_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Upload antivirus scanning (ClamAV / clamd)
# In production this is enabled by default. Set CLAMAV_ENABLED=false to disable (not recommended).
CLAMAV_ENABLED=true
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=15000
# If false (default), uploads fail when scanner is unavailable (safer).
CLAMAV_FAIL_OPEN=false