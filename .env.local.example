# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# For local dev: run `pnpm run webhooks:listen`, then paste the signing secret (whsec_...) here.
# Do not use the Dashboard endpoint URL for localhost; use the CLI instead.
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_PERCENT=10

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@plugdex.io

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Plugdex

